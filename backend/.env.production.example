# Backend production environment
NODE_ENV=production
PORT=5000

# MongoDB (same compose network)
MONGO_URI=mongodb://change_me_user:change_me_password@mongodb:27017/pict_cie?authSource=admin

# JWT secrets (must be strong and different)
JWT_SECRET=change_me_min_32_characters_access_secret
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=change_me_min_32_characters_refresh_secret
JWT_REFRESH_EXPIRE=7d

# Restrict CORS to production origin
CORS_ORIGIN=https://your-domain.com

# AI provider and credentials
AI_PROVIDER=gemini
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# AI service behavior
AI_TIMEOUT_MS=30000
AI_MAX_RETRIES=2
AI_MAX_TOKENS=3000

# AI endpoint limiter
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=20

# Admin seed account
ADMIN_EMAIL=admin@pict.edu
ADMIN_PASSWORD=change_me_strong_admin_password

# Logging
LOG_LEVEL=info
